{
  "name": "archcode",
  "private": true,
  "version": "2.0.0",
  "description": "Physics-based 3D chromatin loop extrusion simulator for variant pathogenicity prediction",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/sergeeey/ARCHCODE"
  },
  "author": "Sergey V. Boyko <sergeikuch80@gmail.com>",
  "homepage": "https://github.com/sergeeey/ARCHCODE#readme",
  "keywords": [
    "chromatin",
    "loop-extrusion",
    "cohesin",
    "variant-pathogenicity",
    "3d-genome",
    "SSIM",
    "ClinVar",
    "bioinformatics"
  ],
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "security:secrets": "python scripts/secret_scan.py",
    "security:deps": "npm audit --audit-level=high",
    "security:python": "python -m bandit -r src scripts tests -lll",
    "preview": "vite preview",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage --coverage.provider=v8 --coverage.thresholds.lines=45 --coverage.thresholds.functions=50 --coverage.thresholds.statements=45 --coverage.thresholds.branches=45",
    "test:gold": "vitest run src/__tests__/regression/gold-standard.test.ts",
    "test:watch": "vitest",
    "test:regression": "vitest run src/__tests__/regression/",
    "validate:hbb": "node scripts/quick-validate.js",
    "validate:hic": "npx tsx scripts/validate-hic.ts",
    "validate:hic:download": "npx tsx scripts/validate-hic.ts --download",
    "validate:hic:list": "npx tsx scripts/validate-hic.ts --list",
    "validate:nature2025": "npx tsx scripts/validate-nature-2025.ts --locus=HBB --runs=1000",
    "validate:sox2": "npx tsx scripts/validate-nature-2025.ts --locus=SOX2 --runs=100",
    "validate:ctcf-kd": "npx tsx scripts/validate-nature-2025.ts --locus=HBB_CTCFKD --runs=100",
    "fountain:myc": "npx tsx scripts/run-fountain-myc.ts",
    "alphagenome:hbb": "npx tsx scripts/validate-alphagenome-hbb.ts",
    "alphagenome:validate": "npx tsx scripts/validate-alphagenome-hbb.ts",
    "alphagenome:setup": "pip install alphagenome && python src/services/alphagenome_wrapper.py check",
    "alphagenome:check": "python src/services/alphagenome_wrapper.py check"
  },
  "dependencies": {
    "@react-three/drei": "^9.88.0",
    "@react-three/fiber": "^8.15.0",
    "@types/d3": "^7.4.3",
    "@types/three": "^0.181.0",
    "@types/uuid": "^10.0.0",
    "d3": "^7.9.0",
    "framer-motion": "^12.29.2",
    "lucide-react": "^0.563.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^7.13.0",
    "three": "^0.181.2",
    "uuid": "^13.0.0",
    "zustand": "^5.0.8"
  },
  "devDependencies": {
    "@gmod/bbi": "^8.1.1",
    "@grpc/grpc-js": "^1.14.3",
    "@grpc/proto-loader": "^0.8.0",
    "@tailwindcss/postcss": "^4.1.18",
    "@types/react": "^18.2.66",
    "@types/react-dom": "^18.2.22",
    "@typescript-eslint/eslint-plugin": "^7.2.0",
    "@typescript-eslint/parser": "^7.2.0",
    "@vitejs/plugin-react": "^5.1.4",
    "@vitest/coverage-v8": "^4.0.18",
    "autoprefixer": "^10.4.24",
    "eslint": "^8.57.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.6",
    "postcss": "^8.5.6",
    "tailwindcss": "^4.1.18",
    "tsx": "^4.21.0",
    "typescript": "^5.2.2",
    "vite": "^7.3.1",
    "vitest": "^4.0.18"
  },
  "overrides": {
    "ajv": "^6.14.0",
    "minimatch": "^9.0.7",
    "@eslint/eslintrc": {
      "minimatch": "^3.1.4"
    },
    "@humanwhocodes/config-array": {
      "minimatch": "^3.1.4"
    },
    "eslint": {
      "minimatch": "^3.1.4"
    },
    "glob": {
      "minimatch": "^3.1.4"
    },
    "rollup": "^4.59.0"
  }
}

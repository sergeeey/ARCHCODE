# ARCHCODE Environment Configuration
# Copy this file to .env and fill in your values

# AlphaGenome API Key (optional)
# Get your key at: https://deepmind.google.com/science/alphagenome
# Without this key, ARCHCODE will use mock predictions
ALPHAGENOME_API_KEY=

# AlphaGenome API URL (optional, use default unless you have a custom endpoint)
# ALPHAGENOME_API_URL=https://api.alphagenome.deepmind.com/v1

# Validation mode: 'mock' or 'live'
# Default: 'mock' (switches to 'live' automatically if API key is provided)
# ALPHAGENOME_MODE=mock

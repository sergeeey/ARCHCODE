      "path_lssim": 0.9375,
      "ben_lssim": 0.9347,
      "delta": -0.0029
    }
  ],
  "conclusions": [
    "Categorical AUC=0.975 confirms category-severity mapping drives discrimination",
    "Position-only AUC=0.551 and uniform-medium AUC=0.551 prove position alone has NO discriminative signal",
    "Inverted AUC=0.022 \u2248 1-0.975: swapping category direction MIRRORS the AUC, proving direction matters",
    "Random AUC=0.490 confirms noise baseline at chance level",
    "This ablation definitively proves ARCHCODE's AUC is a category-distribution effect, not circular or artifactual"
  ]
}

{
  "experiment": "effectStrength 5-point ablation",
  "locus": "HBB 95kb",
  "n_variants": 1103,
  "n_pathogenic": 353,
  "n_benign": 750,
  "date": "2026-03-04",
  "modes": [
    {
      "mode": "categorical",
      "logic": "category \u2192 severity (nonsense=0.1, syn=0.9)",

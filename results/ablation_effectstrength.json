      "path_lssim": 0.8822,
      "ben_lssim": 0.9931,
      "delta": 0.1109
    },
    {
      "mode": "position-only",
      "logic": "fixed 0.3 for ALL variants",
      "auc": 0.551,
      "path_lssim": 0.8952,
      "ben_lssim": 0.8903,
      "delta": -0.0049
    },
    {
      "mode": "uniform-medium",
      "logic": "fixed 0.5 for ALL variants",
      "auc": 0.551,
      "path_lssim": 0.9513,
      "ben_lssim": 0.949,
      "delta": -0.0023
    },
    {
      "mode": "inverted",
      "logic": "SWAPPED (nonsense=0.9, syn=0.1)",

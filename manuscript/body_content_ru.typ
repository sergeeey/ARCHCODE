    align: (auto,auto,auto,auto,auto,auto,),
    table.header([Метрика], [RNA-seq (K562)], [ATAC-seq (K562)], [Карты контактов (2048 bp)], [], [],),
    table.hline(),
    [Среднее max], [ref − alt], [], [28,13], [5,70], [\< 10⁻⁴ (ΔSSIM)],
    [Среднее дельта в бине варианта], [0,38], [0,27], [---], [], [],
    [Среднее косинусное сходство], [0,9954], [0,9205], [\~1,0000], [], [],
    [Средняя концентрация сигнала], [16,97×], [11,15×], [---], [], [],
    [Диапазон max дельта инделов], [99,8--220,7], [23,4--23,9], [---], [], [],
    [Диапазон max дельта SNV], [6,0--15,1], [0,5--6,6], [---], [], [],
  )]
  , kind: table

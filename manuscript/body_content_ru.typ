    table.header([Метрика], [Модальность], [Патогенные (n = 23)], [Доброкачественные (n = 23)], [U], [p-значение], [Размер эффекта r],),
    table.hline(),
    [Дельта в бине варианта], [RNA-seq], [0,074], [0,022], [382,5], [0,0098], [−0,45],
    [Концентрация сигнала], [RNA-seq], [10,71×], [4,45×], [352,0], [0,056], [−0,33],
  )]
  , kind: table
